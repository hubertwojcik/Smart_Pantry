# ====================================================================
#  Szablon zmiennych środowiskowych — skopiuj do `.env` i uzupełnij.
#      cp .env.example .env
# ====================================================================
# Zmienne z prefiksem EXPO_PUBLIC_ są wstrzykiwane do bundla aplikacji.

# --- FIREBASE ---
# Firebase Console -> Project settings -> "Your apps" -> aplikacja Web (</>)
# Skopiuj wartości z obiektu `firebaseConfig`.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- GOOGLE ANALYTICS 4 ---
# measurementId: GA4 -> Admin -> Data Streams -> (Web) -> "G-XXXXXXXXXX"
# apiSecret:     GA4 -> Data Streams -> Measurement Protocol API secrets -> Create
EXPO_PUBLIC_GA4_MEASUREMENT_ID=
EXPO_PUBLIC_GA4_API_SECRET=
